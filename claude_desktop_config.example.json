{
  "mcpServers": {
    "testbridge-runner": {
      "command": "python",
      "args": ["-m", "testbridge_runner.server"],
      "cwd": "/absolute/path/to/testbridge-runner",
      "env": {
        "QA_RUNNER": "pytest",
        "QA_PROJECT_ROOT": "/absolute/path/to/testbridge-runner/tests_project"
      }
    }
  }
}
