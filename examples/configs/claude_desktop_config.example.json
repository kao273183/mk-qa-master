{
  "mcpServers": {
    "mcp-test-runner": {
      "command": "python",
      "args": ["-m", "mcp_test_runner.server"],
      "cwd": "/absolute/path/to/mcp-test-runner",
      "env": {
        "QA_RUNNER": "pytest",
        "QA_PROJECT_ROOT": "/absolute/path/to/mcp-test-runner/tests_project"
      }
    }
  }
}
