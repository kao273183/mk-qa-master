{
  "_comment": "Gemini CLI MCP config — Location: ~/.gemini/settings.json",
  "mcpServers": {
    "mcp-test-runner": {
      "command": "/absolute/path/to/.venv/bin/python",
      "args": ["-m", "mcp_test_runner.server"],
      "cwd": "/absolute/path/to/mcp-test-runner",
      "env": {
        "QA_RUNNER": "pytest",
        "QA_PROJECT_ROOT": "/absolute/path/to/your-test-project"
      }
    }
  }
}
